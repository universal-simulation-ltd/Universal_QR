# Cloudflare Pages rewrites — Universal QR is served under /qr/ but the built
# files in dist/ are flat (Vite's `base` only rewrites URLs INSIDE the HTML; it
# does not place files in dist/qr/).
#
# 200 status = transparent rewrite (URL bar unchanged). Specific rules first,
# broad SPA fallback last.

# Service-worker + PWA artefacts.
/qr/sw.js                /sw.js                200
/qr/registerSW.js        /registerSW.js        200
/qr/manifest.webmanifest /manifest.webmanifest 200
/qr/workbox-*            /workbox-:splat       200

# Hashed asset bundles.
/qr/assets/*             /assets/:splat        200

# Static files referenced from index.html / app code (BASE_URL-prefixed).
/qr/favicon.svg          /favicon.svg          200
/qr/unisim-icon.png      /unisim-icon.png      200
/qr/og-image.png         /og-image.png         200
/qr/icon-180.png         /icon-180.png         200
/qr/icon-192.png         /icon-192.png         200
/qr/icon-512.png         /icon-512.png         200

# SEO crawler files.
/qr/robots.txt           /robots.txt           200
/qr/sitemap.xml          /sitemap.xml          200

# Dynamic QR redirect — a "Dynamic" code encodes /qr/r/<code>; hand it to the
# hosted `qr-redirect` Edge Function, which logs a scan and 302s on to the code's
# current target. MUST sit above the SPA fallback so codes don't load the app
# shell. (External 302, so the redirect happens at the edge, not client-side.)
/qr/r/*                  https://rygfxgalojojppxmhddo.functions.supabase.co/qr-redirect/:splat  302

# SPA fallback — everything else under /qr/ serves the shell.
/qr/*                    /index.html           200
